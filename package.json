{
	"name": "startupkit",
	"private": true,
	"author": "Ian Hunter <ian@01.studio>",
	"description": "Equip your AI agents with startup skills",
	"license": "ISC",
	"type": "module",
	"packageManager": "pnpm@10.28.2",
	"scripts": {
		"clean": "pnpm --stream -r run clean",
		"build": "pnpm --stream -r run build",
		"test": "pnpm --stream -r run test",
		"typecheck": "pnpm --stream -r run typecheck",
		"release": "pnpm build && pnpm --filter \"./packages/**\" -r publish --access public --no-git-checks",
		"startupkit": "node packages/cli/dist/cli.js"
	},
	"devDependencies": {
		"typescript": "5.9.2"
	}
}
