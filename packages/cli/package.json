{
	"name": "startupkit",
	"version": "1.0.0",
	"author": "Ian Hunter <ian@01.studio>",
	"license": "ISC",
	"description": "Equip your AI agents with startup skills - entrepreneur, dev, marketing, and product expertise.",
	"homepage": "https://startupkit.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/ian/startupkit"
	},
	"keywords": ["startup", "ai", "agents", "skills", "claude", "opencode"],
	"files": ["dist"],
	"type": "module",
	"main": "dist/cli.js",
	"bin": {
		"startupkit": "./dist/cli.js"
	},
	"exports": {
		".": {
			"default": "./dist/cli.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"clean": "rm -rf dist",
		"build": "rollup -c",
		"cli": "node dist/cli.js",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@inquirer/prompts": "^8.2.1",
		"commander": "13.1.0"
	},
	"devDependencies": {
		"@rollup/plugin-json": "6.1.0",
		"@rollup/plugin-node-resolve": "16.0.1",
		"@types/node": "22.15.3",
		"rollup": "^4.20.0",
		"rollup-plugin-command": "^1.1.3",
		"rollup-plugin-esbuild": "^6.1.1",
		"typescript": "5.9.2",
		"vitest": "^2.1.8"
	}
}
